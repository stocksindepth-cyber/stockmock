{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "env": {
    "NEXT_PUBLIC_FIREBASE_PROJECT_ID": "optionsindepth"
  },
  "crons": [
    {
      "path": "/api/cron/dhan-renew",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/dhan-renew",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/check-alerts",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/check-alerts",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/lifecycle-nurture",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/poll-chains",
      "schedule": "*/3 * * * *"
    },
    {
      "path": "/api/cron/market-digest",
      "schedule": "15 14 * * 1-5"
    },
    {
      "path": "/api/cron/market-digest",
      "schedule": "45 14 * * 1-5"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
