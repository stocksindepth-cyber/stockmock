rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User document ─────────────────────────────────────────────────────────
    match /users/{userId} {
      // Read own profile only
      allow read: if request.auth != null && request.auth.uid == userId;

      // Create own profile
      allow create: if request.auth != null && request.auth.uid == userId;

      // Update own profile — client can NEVER elevate plan, limits, expiry, or
      // self-grant credits/referral rewards. Those are Admin-SDK only (the Admin
      // SDK bypasses rules entirely).
      //
      // NOTE: must compare CHANGED keys via diff().affectedKeys(). Using
      // request.resource.data.keys() is a footgun — on an update that is the
      // FULL post-write document, which always contains `plan`, so the guard was
      // always false and silently denied EVERY client write (which fail-opened
      // the daily backtest limit and killed activity telemetry).
      allow update: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
             'plan', 'simulationsLimit', 'subscriptionExpiry',
             'backtestCredits', 'referredBy', 'referralRewarded',
             'referralSignups', 'referralConversions'
           ]);

      // No client-side deletes of the user document
      allow delete: if false;

      // ── User subcollections ────────────────────────────────────────────────
      // Covers: activity_logs/*, paperTrades/*, paperTradeProfile/*
      // and any future per-user subcollection (one level deep).
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Backtest results ──────────────────────────────────────────────────────
    match /backtests/{backtestId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create:      if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // ── Payment transactions (created server-side; client can read/create own) ─
    match /transactions/{transactionId} {
      allow read:          if request.auth != null && request.auth.uid == resource.data.userId;
      allow create:        if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false; // Admin SDK only
    }

    // ── Referral code → uid mapping ───────────────────────────────────────────
    // Written by the client when a user first views their referral link; read
    // server-side (Admin SDK) to resolve /r/{code}. A user may only create the
    // mapping that points at themselves.
    match /referralCodes/{code} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Plans — public read, no client writes ─────────────────────────────────
    match /plans/{planId} {
      allow read:  if true;
      allow write: if false;
    }

    // ── Admin config (Dhan token etc.) — server-side Admin SDK only ───────────
    match /admin/{docId} {
      allow read, write: if false;
    }
  }
}
